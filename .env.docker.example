# .env.docker.example — copy to `.env.docker` and (optionally) edit, then:
#   docker compose --env-file .env.docker up --build
# Everything here has a working default baked into docker-compose.yml; this file
# only exists so you can flip on the OPTIONAL providers without editing compose.
# `.env.docker` is gitignored (see .gitignore) — never commit real keys.

# ── Cloudflare Workers AI (flux-1-schnell) — the PRIMARY image provider ─────────
# Leave BOTH blank to run on Pollinations only (free, no key) — the default,
# identical to `nix run .#dev`. Set both to use Cloudflare as primary with a
# Pollinations failover.
CF_API_TOKEN=
CF_ACCOUNT_ID=

# ── Resend (transactional email for the magic link) — OPTIONAL ─────────────────
# Leave blank to skip the email send and use the magic link printed to the server
# log instead:  docker compose logs -f server   →   [magic-link] email=… url=…
RESEND_API_KEY=

# ── Failure-demo gate ──────────────────────────────────────────────────────────
# `?force=timeout|invalid|broken` is honored ONLY for this signed-in account
# (server-authoritative). Empty disables the demo hooks entirely. Default is the
# demo account; change it to YOUR sign-in email to drive the failure states yourself.
DEMO_ACCOUNT_EMAIL=

# ── Byte-validation upper band (rarely changed) ────────────────────────────────
# MAX_BYTES=921600
